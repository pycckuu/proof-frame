# === Blockchain ===
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
DEPLOYER_PRIVATE_KEY=0x...          # For contract deployment
RELAYER_PRIVATE_KEY=0x...           # For anonymous tx submission
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://rpc.sepolia.org  # Client-side RPC for verify page

# === Contract ===
IMAGE_ID=0x...                      # Guest image ID (from cargo build -p proofframe-methods)
USE_MOCK_VERIFIER=true              # true = MockVerifier (dev), false = real Verifier Router

# === ENS / NameStone ===
NAMESTONE_API_KEY=your_key          # From namestone.com dashboard
ENS_DOMAIN=proof-frame.eth         # Parent domain (resolver must be NameStone's)

# === IPFS / Infura ===
INFURA_IPFS_PROJECT_ID=your_id     # From infura.io dashboard
INFURA_IPFS_PROJECT_SECRET=your_secret

# === RISC Zero ===
RISC0_DEV_MODE=1                    # Set for dev, unset for real proofs
RISC0_INFO=1                        # Show cycle counts

# === RunPod Serverless (OPTIONAL — Phase 10) ===
# RUNPOD_API_KEY=rp_xxxxxxxxxxxx
# RUNPOD_ENDPOINT_ID=your-endpoint-id

# === World ID (OPTIONAL) ===
# WORLD_APP_ID=app_staging_xxxxx
# WORLD_ACTION_ID=attest_image

# === Etherscan (OPTIONAL — for contract verification) ===
# ETHERSCAN_API_KEY=your_key
