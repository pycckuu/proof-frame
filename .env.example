# === Blockchain ===
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
DEPLOYER_PRIVATE_KEY=0x...          # For contract deployment
RELAYER_PRIVATE_KEY=0x...           # For anonymous tx submission
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://rpc.sepolia.org  # Client-side RPC for verify page

# === Contract ===
IMAGE_ID=0x...                      # Guest image ID (from cargo build -p proofframe-methods)
USE_MOCK_VERIFIER=true              # true = MockVerifier (dev), false = real Verifier Router

# === ENS / NameStone ===
NAMESTONE_API_KEY=your_key          # From namestone.com dashboard
ENS_DOMAIN=proof-frame.eth         # Parent domain (resolver must be NameStone's)
NEXT_PUBLIC_ENS_DOMAIN=proof-frame.eth  # Client-side ENS domain

# === Static Export (IPFS hosting) ===
# NEXT_PUBLIC_API_BASE=https://your-app.vercel.app  # Backend URL for IPFS-hosted frontend
# STATIC_EXPORT=true                                 # Set to build static export for IPFS

# === IPFS / Infura ===
INFURA_IPFS_PROJECT_ID=your_id     # From infura.io dashboard
INFURA_IPFS_PROJECT_SECRET=your_secret

# === RISC Zero ===
RISC0_DEV_MODE=1                    # Set for dev, unset for real proofs
RISC0_INFO=1                        # Show cycle counts

# === Proof Generation ===
PROVE_PROVIDER=local                       # "local" (dev mode binary) or "runpod" (Phase 10)
PROOFFRAME_HOST_BIN=./target/release/proofframe-host  # Path to compiled host binary

# === RunPod Serverless (required when PROVE_PROVIDER=runpod) ===
RUNPOD_API_KEY=rp_xxxxxxxxxxxx            # From runpod.io → Settings → API Keys
RUNPOD_ENDPOINT_ID=your-endpoint-id       # From runpod.io → Serverless → Endpoint

# === World ID (required — anti-Sybil) ===
USE_MOCK_WORLD_ID=true                                 # true = random nullifier (Sepolia), false = real World ID


WORLD_APP_ID=app_6beb123dab26407b12d1a0aace7e64b8       # World ID app ID (from developer.worldcoin.org)
WORLD_ACTION_ID=attest                                  # World ID action (create in portal)
NEXT_PUBLIC_WORLD_APP_ID=app_6beb123dab26407b12d1a0aace7e64b8  # Client-side for IDKit widget

# === WalletConnect (for Ledger Clear Signing) ===
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id  # From cloud.walletconnect.com

# === Etherscan (OPTIONAL — for contract verification) ===
# ETHERSCAN_API_KEY=your_key
